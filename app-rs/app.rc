#include <winuser.h>

1 ICON "app.ico"

1 24 "app.manifest"

1 VERSIONINFO
FILEVERSION 1,2,3,0
PRODUCTVERSION 1,2,3,0
FILEOS 0x4
FILETYPE 0x1
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "ClaudeUsageBar"
            VALUE "FileDescription", "Claude Usage Bar"
            VALUE "FileVersion", "1.2.3.0"
            VALUE "InternalName", "claude-usage-bar"
            VALUE "OriginalFilename", "claude-usage-bar.exe"
            VALUE "ProductName", "ClaudeUsageBar"
            VALUE "ProductVersion", "1.2.3.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
